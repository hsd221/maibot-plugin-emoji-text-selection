{
  "manifest_version": 2,
  "version": "2.1.0",
  "name": "Emoji Text Selector",
  "description": "表情包选择工具，支持 embedding 语义向量匹配和文本 LLM 选择",
  "author": {
    "name": "hsd221",
    "url": "https://github.com/hsd221"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/hsd221/maibot-plugin-emoji-text-selection",
    "homepage": "https://github.com/hsd221/maibot-plugin-emoji-text-selection",
    "documentation": "https://github.com/hsd221/maibot-plugin-emoji-text-selection",
    "issues": "https://github.com/hsd221/maibot-plugin-emoji-text-selection/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": ["send.emoji", "emoji.get_emotions", "emoji.get_by_description", "llm.embed", "llm.generate", "message.get_recent"],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  },
  "id": "hsd221.emoji-text-selector"
}
